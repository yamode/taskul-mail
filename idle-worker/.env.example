# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# 動作パラメータ (通常デフォルトのままで OK)
LOG_LEVEL=info
HEALTH_PORT=3099
# アカウント一覧の再ポーリング間隔 (ms)
ACCOUNT_POLL_MS=60000
# IDLE の NOOP refresh 間隔 (ms) — 24 分 = RFC 2177 推奨
IDLE_REFRESH_MS=1440000
# EXISTS 通知の連続発火を抑える debounce (ms)
SYNC_DEBOUNCE_MS=3000
